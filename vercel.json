{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/projects", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
